# commerce API（シークレットではない）
# 取得: Railway → decocom_commerce → Settings → Domains の公開 URL
VITE_COMMERCE_API_BASE_URL=https://web-production-7a1c5.up.railway.app

# タイガース埋込の parent_origin 許可リスト（カンマ区切り・シークレットではない）
# 取得: 各 Shopify ストアの公開 URL（Admin → Settings → Domains）
#   jp: https://shop.decocom.jp
#   test: https://decocom-test.myshopify.com
# 本番 Vercel にも同じ変数名で設定すること
VITE_TIGERS_ALLOWED_ORIGINS=https://shop.decocom.jp,https://decocom-test.myshopify.com

# ローカル: commerce を uvicorn で起動したとき
# VITE_COMMERCE_API_BASE_URL=http://localhost:8000
# VITE_EDITOR_ASSETS_SHOP_DOMAIN=decocom-test.myshopify.com